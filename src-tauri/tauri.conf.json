{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Business Ledger App",
  "version": "2.2.0",
  "identifier": "com.business.ledger",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Laundry Cleaning Services",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDMTdBOTEyN0E5QTAwNzUKUldSMUFKcDZFcWtYekFOVUZTbHRZMndMa0xySW9LQ1BGRDBsQUMwbWV5cjNQSVlnTHhKbFBEZU0K",
      "endpoints": [
        "https://github.com/newbie2019-hub/laundry-cleaning/releases/latest/download/latest.json"
      ]
    },
    "sql": {
      "preload": [
        "sqlite:business-ledger.db",
        "sqlite:business-ledger-cleaning.db"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
